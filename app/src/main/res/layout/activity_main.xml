<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_xl"
        android:paddingTop="@dimen/space_xxl"
        android:paddingBottom="@dimen/space_xl">

        <!-- ========== 头部 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="@dimen/space_xxl">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="条码工具"
                    android:textSize="30sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="离线扫码 · 多格式生成 · 批量采集"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="@dimen/elevation_none"
                app:cardBackgroundColor="@color/primary_container">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_scan"
                    android:contentDescription="app icon" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ========== 统计面板 ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- 统计标题行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="@dimen/space_md">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_stats"
                        android:contentDescription="stats" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="扫描统计"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:paddingStart="6dp" />
                </LinearLayout>

                <!-- 三个统计数字 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 今日 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_static"
                        android:padding="@dimen/space_md">
                        <TextView
                            android:id="@+id/stat_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textColor="@color/accent"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:paddingTop="2dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="@dimen/space_sm"
                        android:layout_height="1dp" />

                    <!-- 总计 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_static"
                        android:padding="@dimen/space_md">
                        <TextView
                            android:id="@+id/stat_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总计"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:paddingTop="2dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="@dimen/space_sm"
                        android:layout_height="1dp" />

                    <!-- 去重 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_static"
                        android:padding="@dimen/space_md">
                        <TextView
                            android:id="@+id/stat_unique"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textColor="@color/badge_batch"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="去重"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:paddingTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 功能卡片: 扫码识别 ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_scan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_sm"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_scan"
                    android:contentDescription="scan" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="扫码识别"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14种条码格式 · 结构化解析"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:paddingTop="2dp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.3"
                    android:contentDescription="go" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 功能卡片: 输入生成 ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_sm"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_generate"
                    android:contentDescription="generate" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输入生成"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="一维码 · 二维码 · 多格式输出"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:paddingTop="2dp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.3"
                    android:contentDescription="go" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 功能卡片: 批量扫描 ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_batch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_sm"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_batch"
                    android:contentDescription="batch" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="批量扫描"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="连续扫码 · 实时计数 · CSV导出"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:paddingTop="2dp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.3"
                    android:contentDescription="go" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 功能卡片: 历史记录 ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_sm"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_history"
                    android:contentDescription="history" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="历史记录"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="搜索 · 筛选 · 导出 CSV/JSON"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:paddingTop="2dp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.3"
                    android:contentDescription="go" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 功能卡片: 相册识别 ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_gallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="@dimen/elevation_low"
            app:cardBackgroundColor="@color/bg_surface"
            android:layout_marginBottom="@dimen/space_lg"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_gallery"
                    android:contentDescription="gallery" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="相册识别"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="从图片中识别条码 · 离线解析"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:paddingTop="2dp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.3"
                    android:contentDescription="go" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 底部版本信息 ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v2.0 · 暖色护眼 · 全程离线"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:alpha="0.6" />

    </LinearLayout>
</ScrollView>
