<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="设置"
        app:titleTextColor="@color/on_primary"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section 1: 扫码设置 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="扫码设置"
                        android:layout_marginBottom="@dimen/space_md" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_vibration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="震动反馈"
                        android:checked="true"
                        android:padding="@dimen/space_xs" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="提示音"
                        android:checked="true"
                        android:padding="@dimen/space_xs" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_auto_scan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="连续扫码"
                        android:checked="false"
                        android:padding="@dimen/space_xs" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 2: 条码生成 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="条码生成"
                        android:layout_marginBottom="@dimen/space_md" />

                    <TextView
                        style="@style/Text.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="前景颜色"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_fg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        android:layout_marginBottom="@dimen/space_md" />

                    <TextView
                        style="@style/Text.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="背景颜色"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 3: 内容设置 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="内容设置"
                        android:layout_marginBottom="@dimen/space_md" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="前缀"
                        android:layout_marginBottom="@dimen/space_sm">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_prefix"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="后缀">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_suffix"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        style="@style/Btn.Primary"
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height_md"
        android:layout_margin="@dimen/space_lg"
        android:text="保存设置" />

</LinearLayout>
