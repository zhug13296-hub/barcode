<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_low">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="back" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="历史记录"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/space_sm" />
        <ImageView
            android:id="@+id/btn_export"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_export"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="export" />
    </LinearLayout>

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_sm"
        android:background="@color/bg_surface"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="8dp"
            android:contentDescription="search" />
        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:hint="搜索条码内容..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionSearch" />
    </LinearLayout>

    <!-- 筛选chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_xs"
        android:background="@color/bg_surface">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filter_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacing="6dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

    <!-- 列表 -->
    <ListView
        android:id="@+id/history_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:padding="@dimen/space_sm"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- 空状态 -->
    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="@dimen/elevation_none"
            app:cardBackgroundColor="@color/bg_surface_variant"
            android:layout_marginBottom="@dimen/space_md">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_history"
                android:alpha="0.4"
                android:contentDescription="empty" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无记录"
            android:textSize="15sp"
            android:textColor="@color/text_hint" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫码或生成条码后会自动记录"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:alpha="0.6"
            android:paddingTop="4dp" />
    </LinearLayout>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_lg"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_high"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/btn_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="共 0 条"
            android:textSize="13sp"
            android:textColor="@color/text_hint" />
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_sm"
            android:background="@drawable/bg_btn_danger"
            android:gravity="center"
            android:paddingHorizontal="@dimen/space_lg"
            android:text="清空历史"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
