<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ========== 顶部工具栏 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_low">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="back" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="扫码识别"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/space_sm" />

        <ImageView
            android:id="@+id/btn_gallery"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_gallery"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="gallery"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/btn_flash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flash_off"
            android:padding="8dp"
            android:background="@drawable/bg_flash_toggle"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="flash" />
    </LinearLayout>

    <!-- ========== 格式选择chips ========== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_sm"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_none">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/format_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            app:chipSpacing="6dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

    <!-- ========== 主内容区 ========== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/result_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <!-- 空状态提示 -->
            <LinearLayout
                android:id="@+id/empty_hint"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:gravity="center"
                android:orientation="vertical">
                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="@dimen/radius_xl"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/primary_container"
                    android:layout_marginBottom="@dimen/space_lg">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_scan"
                        android:alpha="0.6"
                        android:contentDescription="scan" />
                </androidx.cardview.widget.CardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击下方按钮开始扫码"
                    android:textSize="15sp"
                    android:textColor="@color/text_hint" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="支持 QR / EAN / UPC / DataMatrix / PDF417 等"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:alpha="0.6"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <!-- 扫码结果卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/result_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_mid"
                app:cardBackgroundColor="@color/bg_surface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- 类型标签行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="@dimen/space_sm">
                        <TextView
                            android:id="@+id/result_type_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="3dp"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/result_format"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:paddingStart="@dimen/space_sm" />
                    </LinearLayout>

                    <!-- 内容 -->
                    <TextView
                        android:id="@+id/result_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textIsSelectable="true"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp"
                        android:paddingBottom="@dimen/space_md" />

                    <!-- 操作按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/btn_action1"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height_sm"
                            android:layout_weight="1"
                            android:background="@drawable/bg_btn_primary"
                            android:gravity="center"
                            android:textColor="@color/on_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/btn_copy"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height_sm"
                            android:layout_weight="1"
                            android:background="@drawable/bg_btn_secondary"
                            android:gravity="center"
                            android:text="复制内容"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 批量结果列表 -->
            <LinearLayout
                android:id="@+id/batch_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="@dimen/space_sm" />

        </LinearLayout>
    </ScrollView>

    <!-- ========== 底部操作栏 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_high">

        <!-- 批量计数栏 -->
        <LinearLayout
            android:id="@+id/batch_counter_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="@dimen/space_sm"
            android:visibility="gone">
            <TextView
                android:id="@+id/batch_count"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_counter"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_lg"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:text="已扫: 0" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/btn_export_batch"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_btn_secondary"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_lg"
                android:text="导出CSV"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 主按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/btn_scan"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_lg"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="开始扫码"
                android:textColor="@color/on_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true" />
            <TextView
                android:id="@+id/btn_toggle_batch"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_lg"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:gravity="center"
                android:text="批量模式"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
