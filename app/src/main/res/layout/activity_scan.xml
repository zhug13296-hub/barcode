<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ========== Top Toolbar ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_lg"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_low">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="back" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="扫码识别"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/space_xs" />

        <ImageView
            android:id="@+id/btn_gallery"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_gallery"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="gallery"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/btn_flash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_flash_off"
            android:padding="10dp"
            android:background="@drawable/bg_flash_toggle"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="flash" />
    </LinearLayout>

    <!-- ========== Format Chips ========== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_sm"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/format_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            app:chipSpacing="6dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

    <!-- ========== Main Content Area ========== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/result_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_xl"
            android:paddingBottom="@dimen/space_lg">

            <!-- ===== Empty State ===== -->
            <LinearLayout
                android:id="@+id/empty_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="280dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_xxl">

                <!-- Scan icon circle -->
                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="@dimen/space_xl">

                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/bg_icon_scan_circle"
                        android:alpha="0.15" />

                    <ImageView
                        android:layout_width="@dimen/icon_xl"
                        android:layout_height="@dimen/icon_xl"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_scan"
                        android:tint="@color/primary"
                        android:contentDescription="scan" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击下方按钮开始扫码"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="结果只做保存、复制和导出"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.02" />
            </LinearLayout>

            <!-- ===== Result Card ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/result_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_mid"
                app:cardBackgroundColor="@color/bg_surface"
                android:layout_marginBottom="@dimen/space_lg"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Type badge + format row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="@dimen/space_md">

                        <TextView
                            android:id="@+id/result_type_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/result_format"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:paddingStart="@dimen/space_sm" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="@dimen/space_md" />

                    <!-- Content text -->
                    <TextView
                        android:id="@+id/result_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textIsSelectable="true"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="@dimen/space_lg" />

                    <!-- Action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btn_action1"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height_md"
                            android:layout_weight="1"
                            android:background="@drawable/bg_btn_primary"
                            android:gravity="center"
                            android:text="继续扫码"
                            android:textColor="@color/on_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:drawableStart="@drawable/ic_scan"
                            android:drawablePadding="6dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_copy"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height_md"
                            android:layout_weight="1"
                            android:background="@drawable/bg_btn_secondary"
                            android:gravity="center"
                            android:text="复制内容"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:drawableStart="@drawable/ic_copy"
                            android:drawablePadding="6dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== Batch Results ===== -->
            <LinearLayout
                android:id="@+id/batch_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="@dimen/space_xs" />

        </LinearLayout>
    </ScrollView>

    <!-- ========== Bottom Bar ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/space_xl"
        android:background="@color/bg_surface"
        android:elevation="@dimen/elevation_high">

        <!-- Batch counter bar -->
        <LinearLayout
            android:id="@+id/batch_counter_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="@dimen/space_md"
            android:visibility="gone">

            <TextView
                android:id="@+id/batch_count"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_counter"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_lg"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:text="已扫: 0" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btn_export_batch"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_btn_secondary"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_lg"
                android:text="导出CSV"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_export"
                android:drawablePadding="4dp"
                android:drawableTint="@color/primary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Main button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_scan"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_lg"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="开始扫码"
                android:textColor="@color/on_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:drawableStart="@drawable/ic_scan"
                android:drawablePadding="8dp"
                android:drawableTint="@color/on_primary"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_toggle_batch"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_lg"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:gravity="center"
                android:text="批量模式"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:drawableStart="@drawable/ic_batch"
                android:drawablePadding="8dp"
                android:drawableTint="@color/primary"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Auto-scan indicator -->
        <TextView
            android:id="@+id/auto_scan_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingTop="@dimen/space_sm"
            android:text="连续扫码中 · 点击停止"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
